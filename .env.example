# ============================================
# LED Cloud 环境变量配置模板
# 复制为 .env 并填入真实值
# cp .env.example .env
# ============================================

# ---------- 微信小程序 ----------
# 从微信公众平台 → 开发管理 → 开发设置 获取
WECHAT_APPID=wx_your_appid_here
WECHAT_SECRET=your_secret_here
# 本地开发时 mock 微信登录，生产环境改为 false
WECHAT_MOCK=true

# ---------- MySQL ----------
MYSQL_ROOT_PASSWORD=change_me_to_secure_password

# ---------- Redis ----------
REDIS_PASSWORD=change_me_redis_password

# ---------- Sentinel Dashboard ----------
SENTINEL_USERNAME=sentinel
SENTINEL_PASSWORD=sentinel

# ---------- Nacos ----------
NACOS_IDENTITY_KEY=led-cloud
NACOS_IDENTITY_VALUE=led-cloud-secret

# ---------- Docker Registry (CI/CD 镜像仓库) ----------
DOCKER_REGISTRY=led-cloud

# ---------- JVM 内存 (可按服务器配置调整) ----------
JAVA_OPTS=-Xms256m -Xmx512m -XX:+UseG1GC -XX:+HeapDumpOnOutOfMemoryError

# ---------- 微服务端口 (默认即可) ----------
# 仅在端口冲突时修改
GATEWAY_PORT=9100
AUTH_PORT=9101
DEVICE_PORT=9102
CONTENT_PORT=9103
SCHEDULE_PORT=9104
FRONTEND_PORT=82

# ---------- MySQL 外部端口 ----------
MYSQL_EXTERNAL_PORT=3310

# ---------- Redis 外部端口 ----------
REDIS_EXTERNAL_PORT=6382

# ---------- MQTT 外部端口 ----------
MQTT_EXTERNAL_PORT=1886
MQTT_WS_EXTERNAL_PORT=9006

# ---------- Nacos 外部端口 ----------
NACOS_EXTERNAL_PORT=8848
NACOS_GRPC_EXTERNAL_PORT=9848

# ---------- Sentinel 外部端口 ----------
SENTINEL_EXTERNAL_PORT=8088

# ---------- Seata 外部端口 ----------
SEATA_EXTERNAL_PORT=8091
SEATA_CONSOLE_EXTERNAL_PORT=7091
